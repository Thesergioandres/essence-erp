# API Configuration
VITE_API_URL=http://localhost:5000/api

# ID de negocio público por defecto (para la landing)
VITE_PUBLIC_BUSINESS_ID=

# Push Notifications (clave pública VAPID)
# Generar en el servidor con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ===== PRODUCCIÓN =====
# Usa la URL de tu backend en el VPS:
# VITE_API_URL=https://tu-dominio/api
