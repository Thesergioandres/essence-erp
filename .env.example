# Variables de entorno para docker-compose
# Copiar a .env y completar con valores reales

# MongoDB
MONGODB_URI=mongodb://mongo:27017/essence

# Redis
REDIS_URL=redis://redis:6379

# JWT - CAMBIAR EN PRODUCCIÓN
JWT_SECRET=CAMBIAR_ESTA_CLAVE_EN_PRODUCCION_MIN_32_CHARS

# Cloudinary
ENABLE_CLOUDINARY=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL
FRONTEND_URL=http://localhost

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Mongo Express (solo desarrollo)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=admin123
