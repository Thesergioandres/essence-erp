[Unit]
Description=Essence App (Docker Compose)
After=network.target docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/youruser/app
ExecStart=/usr/bin/docker compose up -d --build
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target

# Copia este archivo a /etc/systemd/system/essence.service y luego:
# sudo systemctl daemon-reload
# sudo systemctl enable --now essence.service
