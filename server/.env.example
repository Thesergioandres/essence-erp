# MongoDB
MONGODB_URI=mongodb://localhost:27017/essence
# Or for MongoDB Atlas (Production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/essence?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Cloudinary (Opcional - activa solo si tienes credenciales)
ENABLE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis (Opcional - cache)
ENABLE_REDIS_CACHE=false
REDIS_URL=redis://localhost:6379

# CORS
FRONTEND_URL=http://localhost:3000
# In production: https://tu-frontend-en-vps
