# MongoDB
MONGODB_URI=mongodb://localhost:27017/essence
# Or for MongoDB Atlas (Production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/essence?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
# Token durations
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DAYS=7

# Cloudinary (Opcional - activa solo si tienes credenciales)
ENABLE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis (Opcional - cache)
ENABLE_REDIS_CACHE=false
REDIS_URL=redis://localhost:6379

# CORS
FRONTEND_URL=http://localhost:3000
# In production: https://tu-frontend
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Push Notifications (Web Push VAPID Keys)
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@tudominio.com

# Workers (Background Jobs)
BA_ENABLE_WORKER=false
DEBT_WORKER_ENABLED=false
BACKUP_WORKER_DISABLED=true
